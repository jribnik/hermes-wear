<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for all hosts — this is a personal Wear OS app
         connecting to a local self-hosted Hermes Gateway over HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
